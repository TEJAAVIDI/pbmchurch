@model IEnumerable<PBMChurch.Models.Income>

@{
    ViewData["Title"] = "Income Management";
}

<div class="page-header">
    <div class="d-flex justify-content-between align-items-center w-100">
        <div>
            <h2 class="d-none d-md-block"><i class="fas fa-money-bill-wave me-2"></i>Income Management</h2>
            <h5 class="d-md-none mb-0">
                <i class="fas fa-money-bill-wave me-2"></i>
                <span>Income</span><br>
                <span>Management</span>
            </h5>
        </div>
        <button type="button" class="btn btn-success" data-bs-toggle="modal" data-bs-target="#addIncomeModal">
            <i class="fas fa-plus me-2 d-none d-md-inline"></i>
            <i class="fas fa-plus d-md-none"></i>
            <span class="d-none d-md-inline">Add Income</span>
        </button>
    </div>
</div>

<div class="card">
    <div class="card-header">
        <button class="btn btn-link text-decoration-none p-0 w-100 text-start text-white" type="button" data-bs-toggle="collapse" data-bs-target="#filterCollapse">
            <i class="fas fa-filter me-2"></i>Filters
            <i class="fas fa-chevron-down float-end mt-1"></i>
        </button>
    </div>
    <div class="collapse show" id="filterCollapse">
        <div class="card-body">
            <form method="get" class="row g-3 mb-4">
                <div class="col-md-3">
                    <label class="form-label">Church</label>
                    <select name="churchId" class="form-select" onchange="this.form.submit()">
                        <option value="">All Churches</option>
                        @if (ViewBag.Churches != null)
                        {
                            foreach (var item in (Microsoft.AspNetCore.Mvc.Rendering.SelectList)ViewBag.Churches)
                            {
                                <option value="@item.Value" selected="@(item.Selected)">@item.Text</option>
                            }
                        }
                    </select>
                </div>
                <div class="col-md-2">
                    <label class="form-label">Month</label>
                    <select name="month" class="form-select" onchange="this.form.submit()">
                        @for (int m = 1; m <= 12; m++)
                        {
                            <option value="@m" selected="@(ViewBag.SelectedMonth == m)">@(new DateTime(2000, m, 1).ToString("MMMM"))</option>
                        }
                    </select>
                </div>
                <div class="col-md-2">
                    <label class="form-label">Year</label>
                    <select name="year" class="form-select" onchange="this.form.submit()">
                        @for (int y = DateTime.Now.Year; y >= DateTime.Now.Year - 5; y--)
                        {
                            <option value="@y" selected="@(ViewBag.SelectedYear == y)">@y</option>
                        }
                    </select>
                </div>
                <div class="col-md-3">
                    <label class="form-label">&nbsp;</label>
                    <a href="/Finance/Income" class="btn btn-outline-secondary w-100">
                        <i class="fas fa-times me-2"></i>Clear Filters
                    </a>
                </div>
                <div class="col-md-2 d-none d-md-block">
                    <label class="form-label">&nbsp;</label>
                    <a href="/Finance/ProfitLoss" class="btn btn-info w-100">
                        <i class="fas fa-chart-pie me-2"></i>Profit/Loss
                    </a>
                </div>
            </form>
        </div>
    </div>
</div>

<!-- Mobile Profit/Loss Button -->
<div class="d-md-none mb-3">
    <a href="/Finance/ProfitLoss" class="btn btn-info">
        <i class="fas fa-chart-pie me-2"></i>Profit/Loss
    </a>
</div>

        <div class="alert alert-success">
            <strong>Total Income:</strong> ₹ @(Model?.Sum(i => i.Amount).ToString("N2") ?? "0.00")
        </div>

        <div class="table-responsive d-none d-md-block">
            <table class="table table-striped table-hover">
                <thead>
                    <tr>
                        <th>Date</th>
                        <th>Church</th>
                        <th>Source</th>
                        <th>Description</th>
                        <th>Amount</th>
                        <th>Actions</th>
                    </tr>
                </thead>
                <tbody>
                    @if (Model != null && Model.Any())
                    {
                        @foreach (var item in Model)
                        {
                            <tr>
                                <td>@item.IncomeDate.ToString("MMM dd, yyyy")</td>
                                <td>@item.Church?.ChurchName</td>
                                <td><span class="badge bg-info">@item.Source</span></td>
                                <td>@item.Description</td>
                                <td><strong>₹ @item.Amount.ToString("N2")</strong></td>
                                <td>
                                    <button class="btn btn-sm btn-primary" onclick="editIncome(@item.IncomeId)" title="Edit">
                                        <i class="fas fa-edit"></i>
                                    </button>
                                    <form method="post" asp-action="DeleteIncome" asp-route-id="@item.IncomeId" style="display:inline;" 
                                          onsubmit="return confirm('Are you sure you want to delete this income record?');">
                                        @Html.AntiForgeryToken()
                                        <button type="submit" class="btn btn-sm btn-danger" title="Delete">
                                            <i class="fas fa-trash"></i>
                                        </button>
                                    </form>
                                </td>
                            </tr>
                        }
                    }
                    else
                    {
                        <tr>
                            <td colspan="6" class="text-center text-muted">No income records found</td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>

        <!-- Mobile Card View -->
        <div class="d-md-none">
            @if (Model != null && Model.Any())
            {
                @foreach (var item in Model)
                {
                    <div class="card mb-3">
                        <div class="card-body">
                            <div class="d-flex justify-content-between align-items-start mb-2">
                                <h6 class="card-title mb-0">@item.Church?.ChurchName</h6>
                                <span class="badge bg-info">@item.Source</span>
                            </div>
                            <p class="mb-1"><strong>Date:</strong> @item.IncomeDate.ToString("MMM dd, yyyy")</p>
                            <p class="mb-1"><strong>Amount:</strong> <span class="text-success fw-bold">₹ @item.Amount.ToString("N2")</span></p>
                            <p class="mb-3"><strong>Description:</strong> @(item.Description ?? "N/A")</p>
                            <div class="d-flex gap-2">
                                <button class="btn btn-sm btn-primary" onclick="editIncome(@item.IncomeId)" title="Edit">
                                    <i class="fas fa-edit me-1"></i>Edit
                                </button>
                                <form method="post" asp-action="DeleteIncome" asp-route-id="@item.IncomeId" style="display:inline;" 
                                      onsubmit="return confirm('Are you sure you want to delete this income record?');">
                                    @Html.AntiForgeryToken()
                                    <button type="submit" class="btn btn-sm btn-danger" title="Delete">
                                        <i class="fas fa-trash me-1"></i>Delete
                                    </button>
                                </form>
                            </div>
                        </div>
                    </div>
                }
            }
            else
            {
                <div class="card">
                    <div class="card-body text-center py-5">
                        <i class="fas fa-money-bill-wave fa-3x text-muted mb-3 d-block"></i>
                        <p class="text-muted">No income records found</p>
                    </div>
                </div>
            }
        </div>
    </div>
</div>

<!-- Add Income Modal -->
<div class="modal fade" id="addIncomeModal" tabindex="-1">
    <div class="modal-dialog">
        <div class="modal-content">
            <div class="modal-header bg-success text-white">
                <h5 class="modal-title">Add Income</h5>
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
            </div>
            <form method="post" asp-action="CreateIncome">
                @Html.AntiForgeryToken()
                <div class="modal-body">
                    <div class="mb-3">
                        <label class="form-label">Church <span class="text-danger">*</span></label>
                        <select name="ChurchId" class="form-select" required>
                            <option value="">Select Church</option>
                            @if (ViewBag.Churches != null)
                            {
                                foreach (var item in (Microsoft.AspNetCore.Mvc.Rendering.SelectList)ViewBag.Churches)
                                {
                                    <option value="@item.Value">@item.Text</option>
                                }
                            }
                        </select>
                    </div>
                    <div class="mb-3">
                        <label class="form-label">Date <span class="text-danger">*</span></label>
                        <input type="date" name="IncomeDate" class="form-control" value="@DateTime.Today.ToString("yyyy-MM-dd")" required />
                    </div>
                    <div class="mb-3">
                        <label class="form-label">Source <span class="text-danger">*</span></label>
                        <select name="Source" class="form-select" required>
                            <option value="">Select Source</option>
                            <option value="Offering">Offering</option>
                            <option value="Tithe">Tithe</option>
                            <option value="Donation">Donation</option>
                            <option value="Event">Event</option>
                            <option value="Other">Other</option>
                        </select>
                    </div>
                    <div class="mb-3">
                        <label class="form-label">Amount <span class="text-danger">*</span></label>
                        <input type="number" name="Amount" class="form-control" step="0.01" min="0.01" required />
                    </div>
                    <div class="mb-3">
                        <label class="form-label">Description</label>
                        <textarea name="Description" class="form-control" rows="3"></textarea>
                    </div>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
                    <button type="submit" class="btn btn-success">
                        <i class="fas fa-save me-2"></i>Add Income
                    </button>
                </div>
            </form>
        </div>
    </div>
</div>

<!-- Edit Income Modal -->
<div class="modal fade" id="editIncomeModal" tabindex="-1">
    <div class="modal-dialog">
        <div class="modal-content">
            <div class="modal-header bg-primary text-white">
                <h5 class="modal-title">Edit Income</h5>
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
            </div>
            <form id="editIncomeForm">
                @Html.AntiForgeryToken()
                <input type="hidden" id="editIncomeId" name="IncomeId" />
                <div class="modal-body">
                    <div class="mb-3">
                        <label class="form-label">Church <span class="text-danger">*</span></label>
                        <select id="editChurchId" name="ChurchId" class="form-select" required>
                            <option value="">Select Church</option>
                            @if (ViewBag.Churches != null)
                            {
                                foreach (var item in (Microsoft.AspNetCore.Mvc.Rendering.SelectList)ViewBag.Churches)
                                {
                                    <option value="@item.Value">@item.Text</option>
                                }
                            }
                        </select>
                    </div>
                    <div class="mb-3">
                        <label class="form-label">Date <span class="text-danger">*</span></label>
                        <input type="date" id="editIncomeDate" name="IncomeDate" class="form-control" required />
                    </div>
                    <div class="mb-3">
                        <label class="form-label">Source <span class="text-danger">*</span></label>
                        <select id="editSource" name="Source" class="form-select" required>
                            <option value="">Select Source</option>
                            <option value="Offering">Offering</option>
                            <option value="Tithe">Tithe</option>
                            <option value="Donation">Donation</option>
                            <option value="Event">Event</option>
                            <option value="Other">Other</option>
                        </select>
                    </div>
                    <div class="mb-3">
                        <label class="form-label">Amount <span class="text-danger">*</span></label>
                        <input type="number" id="editAmount" name="Amount" class="form-control" step="0.01" min="0.01" required />
                    </div>
                    <div class="mb-3">
                        <label class="form-label">Description</label>
                        <textarea id="editDescription" name="Description" class="form-control" rows="3"></textarea>
                    </div>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
                    <button type="submit" class="btn btn-primary">
                        <i class="fas fa-save me-2"></i>Update Income
                    </button>
                </div>
            </form>
        </div>
    </div>
</div>

<script>
function editIncome(incomeId) {
    $.get('/Finance/GetIncomeForEdit/' + incomeId, function(response) {
        if (response.success) {
            $('#editIncomeId').val(response.income.incomeId);
            $('#editChurchId').val(response.income.churchId);
            $('#editIncomeDate').val(response.income.incomeDate);
            $('#editSource').val(response.income.source);
            $('#editAmount').val(response.income.amount);
            $('#editDescription').val(response.income.description);
            $('#editIncomeModal').modal('show');
        }
    });
}

$('#editIncomeForm').on('submit', function(e) {
    e.preventDefault();
    
    $.post('/Finance/UpdateIncome', $(this).serialize(), function(response) {
        if (response.success) {
            $('#editIncomeModal').modal('hide');
            location.reload();
        } else {
            alert('Error: ' + (response.message || 'Failed to update income'));
        }
    });
});
</script>
