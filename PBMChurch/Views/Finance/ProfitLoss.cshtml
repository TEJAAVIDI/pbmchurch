@using PBMChurch.Controllers
@{
    ViewData["Title"] = "Profit/Loss Report";
    var monthlyData = ViewBag.MonthlyData as List<FinanceController.MonthlyFinancialData>;
}

<div class="page-header d-flex justify-content-between align-items-center">
    <h2><i class="fas fa-chart-pie me-2"></i>Profit/Loss Report - Month Wise</h2>
    <div>
        <a href="/Finance/Income" class="btn btn-success me-2">
            <i class="fas fa-money-bill-wave me-2"></i>Income
        </a>
        <a href="/Finance/Expense" class="btn btn-danger">
            <i class="fas fa-receipt me-2"></i>Expenses
        </a>
    </div>
</div>

<div class="card mb-4">
    <div class="card-body">
        <form method="get" class="row g-3">
            <div class="col-md-5">
                <label class="form-label">Church</label>
                <select name="churchId" class="form-select" onchange="this.form.submit()">
                    <option value="">All Churches</option>
                    @if (ViewBag.Churches != null)
                    {
                        foreach (var item in (Microsoft.AspNetCore.Mvc.Rendering.SelectList)ViewBag.Churches)
                        {
                            <option value="@item.Value" selected="@(item.Selected)">@item.Text</option>
                        }
                    }
                </select>
            </div>
            <div class="col-md-3">
                <label class="form-label">Year</label>
                <select name="year" class="form-select" onchange="this.form.submit()">
                    @for (int y = DateTime.Now.Year; y >= DateTime.Now.Year - 5; y--)
                    {
                        <option value="@y" selected="@(ViewBag.SelectedYear == y)">@y</option>
                    }
                </select>
            </div>
            <div class="col-md-4">
                <label class="form-label">&nbsp;</label>
                <a href="/Finance/ProfitLoss" class="btn btn-outline-secondary w-100">
                    <i class="fas fa-times me-2"></i>Clear Filters
                </a>
            </div>
        </form>
    </div>
</div>

<!-- Year Summary Cards -->
<div class="row mb-4">
    <div class="col-md-4">
        <div class="card text-white bg-success">
            <div class="card-body">
                <h6 class="card-title">Total Income (@ViewBag.SelectedYear)</h6>
                <h3 class="mb-0">₹ @(((decimal)ViewBag.YearIncome).ToString("N2"))</h3>
            </div>
        </div>
    </div>
    <div class="col-md-4">
        <div class="card text-white bg-danger">
            <div class="card-body">
                <h6 class="card-title">Total Expenses (@ViewBag.SelectedYear)</h6>
                <h3 class="mb-0">₹ @(((decimal)ViewBag.YearExpenses).ToString("N2"))</h3>
            </div>
        </div>
    </div>
    <div class="col-md-4">
        <div class="card text-white @(((decimal)ViewBag.YearProfit) >= 0 ? "bg-primary" : "bg-warning")">
            <div class="card-body">
                <h6 class="card-title">Net Profit/Loss (@ViewBag.SelectedYear)</h6>
                <h3 class="mb-0">₹ @(((decimal)ViewBag.YearProfit).ToString("N2"))</h3>
            </div>
        </div>
    </div>
</div>

<!-- Monthly Breakdown Table -->
<div class="card">
    <div class="card-header bg-info text-white">
        <h5 class="mb-0">
            <i class="fas fa-calendar-alt me-2"></i>Month-wise Breakdown
            @if (!string.IsNullOrEmpty(ViewBag.SelectedChurchName))
            {
                <span> - @ViewBag.SelectedChurchName</span>
            }
            else
            {
                <span> - All Churches</span>
            }
        </h5>
    </div>
    <div class="card-body">
        <div class="table-responsive">
            <table class="table table-striped table-hover">
                <thead>
                    <tr>
                        <th>Month</th>
                        <th class="text-end">Income</th>
                        <th class="text-end">Expenses</th>
                        <th class="text-end">Profit/Loss</th>
                        <th class="text-center">Status</th>
                    </tr>
                </thead>
                <tbody>
                    @if (monthlyData != null && monthlyData.Any())
                    {
                        @foreach (var month in monthlyData)
                        {
                            var profitClass = month.Profit >= 0 ? "text-success" : "text-danger";
                            var statusIcon = month.Profit >= 0 ? "fa-arrow-up" : "fa-arrow-down";
                            var statusBadge = month.Profit >= 0 ? "bg-success" : "bg-danger";
                            
                            <tr>
                                <td><strong>@month.Month</strong></td>
                                <td class="text-end text-success">₹ @month.Income.ToString("N2")</td>
                                <td class="text-end text-danger">₹ @month.Expenses.ToString("N2")</td>
                                <td class="text-end @profitClass">
                                    <strong>₹ @month.Profit.ToString("N2")</strong>
                                </td>
                                <td class="text-center">
                                    <span class="badge @statusBadge">
                                        <i class="fas @statusIcon me-1"></i>
                                        @(month.Profit >= 0 ? "Profit" : "Loss")
                                    </span>
                                </td>
                            </tr>
                        }
                    }
                    else
                    {
                        <tr>
                            <td colspan="5" class="text-center text-muted">No financial data found</td>
                        </tr>
                    }
                </tbody>
                <tfoot class="table-dark">
                    <tr>
                        <th>TOTAL (@ViewBag.SelectedYear)</th>
                        <th class="text-end">₹ @(((decimal)ViewBag.YearIncome).ToString("N2"))</th>
                        <th class="text-end">₹ @(((decimal)ViewBag.YearExpenses).ToString("N2"))</th>
                        <th class="text-end">₹ @(((decimal)ViewBag.YearProfit).ToString("N2"))</th>
                        <th class="text-center">
                            @if (((decimal)ViewBag.YearProfit) >= 0)
                            {
                                <span class="badge bg-success">
                                    <i class="fas fa-check-circle me-1"></i>Profitable Year
                                </span>
                            }
                            else
                            {
                                <span class="badge bg-danger">
                                    <i class="fas fa-exclamation-circle me-1"></i>Loss Year
                                </span>
                            }
                        </th>
                    </tr>
                </tfoot>
            </table>
        </div>
    </div>
</div>

<!-- Print Button -->
<div class="text-end mt-3">
    <button class="btn btn-secondary" onclick="window.print()">
        <i class="fas fa-print me-2"></i>Print Report
    </button>
</div>

<style>
    @@media print {
        .page-header button,
        .card-body form,
        .btn {
            display: none !important;
        }
    }
</style>
