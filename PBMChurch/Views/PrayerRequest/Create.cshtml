@model PBMChurch.Models.PrayerRequest

@{
    ViewData["Title"] = "Add Prayer Request";
}

<div class="container-fluid">
    <div class="row">
        <div class="col-12">
            <div class="d-flex justify-content-between align-items-center mb-4">
                <h2><i class="fas fa-praying-hands me-2"></i>Add Prayer Request</h2>
                <a asp-action="Index" class="btn btn-secondary">
                    <i class="fas fa-arrow-left me-1"></i>Back to List
                </a>
            </div>

            <div class="card">
                <div class="card-body">
                    <form asp-action="Create" method="post">
                        <div class="row">
                            <!-- Member Search Section -->
                            <div class="col-md-6">
                                <div class="card mb-3">
                                    <div class="card-header">
                                        <h5>Search Member (Optional)</h5>
                                    </div>
                                    <div class="card-body">
                                        <div class="row">
                                            <div class="col-md-6">
                                                <label class="form-label">Church</label>
                                                <select id="searchChurch" class="form-select">
                                                    <option value="">Select Church</option>
                                                    @foreach (var church in ViewBag.Churches as SelectList)
                                                    {
                                                        <option value="@church.Value">@church.Text</option>
                                                    }
                                                </select>
                                            </div>
                                            <div class="col-md-6">
                                                <label class="form-label">Member Name</label>
                                                <input type="text" id="searchName" class="form-control" placeholder="Enter member name">
                                            </div>
                                        </div>
                                        <div class="mt-2">
                                            <button type="button" id="searchBtn" class="btn btn-info">
                                                <i class="fas fa-search"></i> Search Member
                                            </button>
                                        </div>
                                        <div id="searchResult" class="mt-2"></div>
                                    </div>
                                </div>
                            </div>

                            <!-- Prayer Request Form -->
                            <div class="col-md-6">
                                <div class="mb-3">
                                    <label asp-for="Name" class="form-label">Name *</label>
                                    <input asp-for="Name" class="form-control" required>
                                    <span asp-validation-for="Name" class="text-danger"></span>
                                </div>

                                <div class="mb-3">
                                    <label asp-for="Phone" class="form-label">Phone</label>
                                    <input asp-for="Phone" class="form-control">
                                    <span asp-validation-for="Phone" class="text-danger"></span>
                                </div>

                                <div class="mb-3">
                                    <label asp-for="ChurchId" class="form-label">Church</label>
                                    <select asp-for="ChurchId" class="form-select" asp-items="ViewBag.Churches">
                                        <option value="">No Church (General Request)</option>
                                    </select>
                                    <span asp-validation-for="ChurchId" class="text-danger"></span>
                                </div>

                                <input type="hidden" asp-for="MemberId" id="memberId">
                            </div>
                        </div>

                        <div class="row">
                            <div class="col-12">
                                <div class="mb-3">
                                    <label asp-for="Title" class="form-label">Prayer Request Title</label>
                                    <input asp-for="Title" class="form-control" placeholder="Brief title for the prayer request...">
                                    <span asp-validation-for="Title" class="text-danger"></span>
                                </div>

                                <div class="mb-3">
                                    <label asp-for="Request" class="form-label">Prayer Request Details *</label>
                                    <textarea asp-for="Request" class="form-control" rows="4" required placeholder="Enter the prayer request details..."></textarea>
                                    <span asp-validation-for="Request" class="text-danger"></span>
                                </div>

                                <div class="mb-3">
                                    <label asp-for="Notes" class="form-label">Additional Notes</label>
                                    <textarea asp-for="Notes" class="form-control" rows="2" placeholder="Any additional notes..."></textarea>
                                    <span asp-validation-for="Notes" class="text-danger"></span>
                                </div>
                            </div>
                        </div>

                        <div class="d-flex justify-content-end">
                            <button type="submit" class="btn btn-primary">
                                <i class="fas fa-save me-1"></i>Save Prayer Request
                            </button>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>

<script>
    document.getElementById('searchBtn').addEventListener('click', function() {
        const name = document.getElementById('searchName').value;
        const churchId = document.getElementById('searchChurch').value;
        
        if (!name) {
            alert('Please enter a member name to search');
            return;
        }

        fetch(`/PrayerRequest/SearchMember?name=${encodeURIComponent(name)}&churchId=${churchId}`)
            .then(response => response.json())
            .then(data => {
                const resultDiv = document.getElementById('searchResult');
                
                if (data.found) {
                    resultDiv.innerHTML = `
                        <div class="alert alert-success">
                            <strong>Member Found:</strong> ${data.name}<br>
                            <strong>Church:</strong> ${data.churchName || 'No Church'}<br>
                            <strong>Phone:</strong> ${data.phone || 'Not provided'}
                            <button type="button" class="btn btn-sm btn-primary mt-2" onclick="fillMemberData(${data.memberId}, '${data.name}', '${data.phone || ''}', ${data.churchId || 'null'})">
                                Use This Member
                            </button>
                        </div>
                    `;
                } else {
                    resultDiv.innerHTML = `
                        <div class="alert alert-warning">
                            <strong>Member not found.</strong> You can proceed with creating a prayer request for a non-member.
                        </div>
                    `;
                }
            })
            .catch(error => {
                document.getElementById('searchResult').innerHTML = `
                    <div class="alert alert-danger">Error searching member. Please try again.</div>
                `;
            });
    });

    function fillMemberData(memberId, name, phone, churchId) {
        document.getElementById('Name').value = name;
        document.getElementById('Phone').value = phone;
        document.getElementById('ChurchId').value = churchId || '';
        document.getElementById('memberId').value = memberId;
        
        // Clear the request details for user to enter
        document.getElementById('Request').value = '';
        document.getElementById('Request').focus();
        
        document.getElementById('searchResult').innerHTML = `
            <div class="alert alert-info">
                Member details filled. Please enter the prayer request details below.
            </div>
        `;
    }
</script>