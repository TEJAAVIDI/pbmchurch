@model IEnumerable<PBMChurch.Models.Church>

@{
    ViewData["Title"] = "Church Management";
}

<div class="page-header">
    <div class="d-flex justify-content-between align-items-center w-100">
        <h2><i class="fas fa-church me-2"></i><span class="d-none d-sm-inline">Church Management</span><span class="d-sm-none">Churches</span></h2>
        <a asp-action="Create" class="btn btn-primary">
            <i class="fas fa-plus me-1"></i><span class="d-none d-md-inline">Add New Church</span><span class="d-md-none">Add</span>
        </a>
    </div>
</div>

<!-- Desktop Table View -->
<div class="card d-none d-md-block">
    <div class="card-body">
        <div class="table-responsive">
            <table class="table table-hover">
                <thead>
                    <tr>
                        <th>Church Name</th>
                        <th>Location</th>
                        <th>Meeting Days</th>
                        <th>Status</th>
                        <th>Created Date</th>
                        <th>Actions</th>
                    </tr>
                </thead>
                <tbody>
                    @if (Model != null && Model.Any())
                    {
                        @foreach (var church in Model)
                        {
                            <tr>
                                <td><strong>@church.ChurchName</strong></td>
                                <td>@church.Location</td>
                                <td>
                                    <span class="badge bg-dark text-white">@church.MeetingDay1</span>
                                    <span class="badge bg-dark text-white">@church.MeetingDay2</span>
                                </td>
                                <td>
                                    @if (church.Status == "Active")
                                    {
                                        <span class="badge bg-success">Active</span>
                                    }
                                    else
                                    {
                                        <span class="badge bg-secondary">Inactive</span>
                                    }
                                </td>
                                <td>@church.CreatedDate.ToString("MMM dd, yyyy")</td>
                                <td>
                                    <div class="dropdown">
                                        <button class="btn btn-sm btn-outline-secondary" type="button" data-bs-toggle="dropdown">
                                            <i class="fas fa-ellipsis-v"></i>
                                        </button>
                                        <ul class="dropdown-menu">
                                            <li><a class="dropdown-item" asp-action="Details" asp-route-id="@church.ChurchId"><i class="fas fa-eye me-2"></i>View</a></li>
                                            <li><a class="dropdown-item" asp-action="Edit" asp-route-id="@church.ChurchId"><i class="fas fa-edit me-2"></i>Edit</a></li>
                                            @if (church.Status == "Active")
                                            {
                                                <li><hr class="dropdown-divider"></li>
                                                <li>
                                                    <form asp-action="Delete" asp-route-id="@church.ChurchId" method="post" class="d-inline" 
                                                          onsubmit="return confirm('Are you sure you want to deactivate this church?');">
                                                        @Html.AntiForgeryToken()
                                                        <button type="submit" class="dropdown-item text-danger">
                                                            <i class="fas fa-times-circle me-2"></i>Deactivate
                                                        </button>
                                                    </form>
                                                </li>
                                            }
                                            else
                                            {
                                                <li><hr class="dropdown-divider"></li>
                                                <li>
                                                    <form asp-action="Reactivate" asp-route-id="@church.ChurchId" method="post" class="d-inline" 
                                                          onsubmit="return confirm('Are you sure you want to reactivate this church?');">
                                                        @Html.AntiForgeryToken()
                                                        <button type="submit" class="dropdown-item text-success">
                                                            <i class="fas fa-check-circle me-2"></i>Reactivate
                                                        </button>
                                                    </form>
                                                </li>
                                            }
                                        </ul>
                                    </div>
                                </td>
                            </tr>
                        }
                    }
                    else
                    {
                        <tr>
                            <td colspan="6" class="text-center py-4">
                                <i class="fas fa-church fa-3x text-muted mb-3 d-block"></i>
                                <p class="text-muted">No churches found. Click "Add New Church" to get started.</p>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>

<!-- Mobile Card View -->
<div class="d-md-none">
    @if (Model != null && Model.Any())
    {
        @foreach (var church in Model)
        {
            <div class="card mb-3">
                <div class="card-body">
                    <div class="d-flex justify-content-between align-items-start">
                        <div class="flex-grow-1">
                            <h5 class="card-title mb-2">@church.ChurchName</h5>
                            <p class="card-text mb-1"><i class="fas fa-map-marker-alt me-2 text-muted"></i>@church.Location</p>
                            <div class="mb-2">
                                <span class="badge bg-dark me-1 text-white">@church.MeetingDay1</span>
                                <span class="badge bg-dark text-white">@church.MeetingDay2</span>
                            </div>
                            <div class="mb-2">
                                @if (church.Status == "Active")
                                {
                                    <span class="badge bg-success">Active</span>
                                }
                                else
                                {
                                    <span class="badge bg-secondary">Inactive</span>
                                }
                            </div>
                            <small class="text-muted"><i class="fas fa-calendar me-1"></i>Created: @church.CreatedDate.ToString("MMM dd, yyyy")</small>
                        </div>
                        <div class="dropdown">
                            <button class="btn btn-sm btn-outline-secondary" type="button" data-bs-toggle="dropdown">
                                <i class="fas fa-ellipsis-v"></i>
                            </button>
                            <ul class="dropdown-menu dropdown-menu-end">
                                <li><a class="dropdown-item" asp-action="Details" asp-route-id="@church.ChurchId"><i class="fas fa-eye me-2"></i>View</a></li>
                                <li><a class="dropdown-item" asp-action="Edit" asp-route-id="@church.ChurchId"><i class="fas fa-edit me-2"></i>Edit</a></li>
                                @if (church.Status == "Active")
                                {
                                    <li><hr class="dropdown-divider"></li>
                                    <li>
                                        <form asp-action="Delete" asp-route-id="@church.ChurchId" method="post" class="d-inline" 
                                              onsubmit="return confirm('Are you sure you want to deactivate this church?');">
                                            @Html.AntiForgeryToken()
                                            <button type="submit" class="dropdown-item text-danger">
                                                <i class="fas fa-times-circle me-2"></i>Deactivate
                                            </button>
                                        </form>
                                    </li>
                                }
                                else
                                {
                                    <li><hr class="dropdown-divider"></li>
                                    <li>
                                        <form asp-action="Reactivate" asp-route-id="@church.ChurchId" method="post" class="d-inline" 
                                              onsubmit="return confirm('Are you sure you want to reactivate this church?');">
                                            @Html.AntiForgeryToken()
                                            <button type="submit" class="dropdown-item text-success">
                                                <i class="fas fa-check-circle me-2"></i>Reactivate
                                            </button>
                                        </form>
                                    </li>
                                }
                            </ul>
                        </div>
                    </div>
                </div>
            </div>
        }
    }
    else
    {
        <div class="card">
            <div class="card-body text-center py-5">
                <i class="fas fa-church fa-3x text-muted mb-3 d-block"></i>
                <p class="text-muted">No churches found. Click "Add New Church" to get started.</p>
            </div>
        </div>
    }
</div>