@model IEnumerable<PBMChurch.Models.ChurchActivity>
@{
    ViewData["Title"] = "Church Activities";
}

<div class="page-header">
    <h2><i class="fas fa-calendar-alt me-2"></i>Church Activities</h2>
</div>

<div class="card">
    <div class="card-header d-flex justify-content-between align-items-center">
        <h5 class="mb-0">Manage Church Activities</h5>
        <a href="@Url.Action("Create")" class="btn btn-primary">
            <i class="fas fa-plus me-1"></i>Add New Activity
        </a>
    </div>
    <div class="card-body">
        @if (Model.Any())
        {
            <div class="row">
                @foreach (var activity in Model)
                {
                    <div class="col-md-6 col-lg-4 mb-4">
                        <div class="card h-100 border-left-primary">
                            <div class="card-body">
                                <h5 class="card-title text-primary">
                                    <i class="fas fa-calendar-check me-2"></i>@activity.Title
                                </h5>
                                <div class="mb-3">
                                    <small class="text-muted">
                                        <i class="fas fa-clock me-1"></i>
                                        <strong>From:</strong> @activity.FromDateTime.ToString("MMM dd, yyyy hh:mm tt")
                                    </small>
                                    <br>
                                    <small class="text-muted">
                                        <i class="fas fa-clock me-1"></i>
                                        <strong>To:</strong> @activity.ToDateTime.ToString("MMM dd, yyyy hh:mm tt")
                                    </small>
                                </div>
                                <p class="card-text">@activity.Description</p>
                                <div class="mb-3">
                                    <small class="text-info">
                                        <i class="fas fa-map-marker-alt me-1"></i>
                                        <strong>Location:</strong> @activity.Location
                                    </small>
                                </div>
                            </div>
                            <div class="card-footer bg-transparent">
                                <div class="btn-group w-100" role="group">
                                    <a href="@Url.Action("Edit", new { id = activity.Id })" class="btn btn-outline-primary btn-sm">
                                        <i class="fas fa-edit"></i> Edit
                                    </a>
                                    <button type="button" class="btn btn-outline-danger btn-sm" onclick="deleteActivity(@activity.Id)">
                                        <i class="fas fa-trash"></i> Delete
                                    </button>
                                </div>
                            </div>
                        </div>
                    </div>
                }
            </div>
        }
        else
        {
            <div class="text-center py-5">
                <i class="fas fa-calendar-times fa-3x text-muted mb-3"></i>
                <h5 class="text-muted">No activities found</h5>
                <p class="text-muted">Start by adding your first church activity.</p>
                <a href="@Url.Action("Create")" class="btn btn-primary">
                    <i class="fas fa-plus me-1"></i>Add First Activity
                </a>
            </div>
        }
    </div>
</div>

<script>
function deleteActivity(id) {
    if (confirm('Are you sure you want to delete this activity?')) {
        $.post('@Url.Action("Delete")', { id: id }, function(response) {
            location.reload();
        });
    }
}
</script>