@model PBMChurch.Models.ChurchActivity
@{
    ViewData["Title"] = "Edit Church Activity";
}

<div class="page-header">
    <h2><i class="fas fa-edit me-2"></i>Edit Church Activity</h2>
</div>

<div class="card">
    <div class="card-header">
        <h5 class="mb-0">Update Activity Details</h5>
    </div>
    <div class="card-body">
        <form asp-action="Edit" method="post" enctype="multipart/form-data">
            @Html.AntiForgeryToken()
            <input asp-for="Id" type="hidden" />
            <input asp-for="CreatedDate" type="hidden" />
            
            <div class="row">
                <div class="col-md-6">
                    <div class="mb-3">
                        <label asp-for="Title" class="form-label">Activity Title</label>
                        <input asp-for="Title" class="form-control" placeholder="Enter activity title" />
                        <span asp-validation-for="Title" class="text-danger"></span>
                    </div>
                </div>
                <div class="col-md-6">
                    <div class="mb-3">
                        <label asp-for="Location" class="form-label">Location</label>
                        <input asp-for="Location" class="form-control" placeholder="Enter location" />
                        <span asp-validation-for="Location" class="text-danger"></span>
                    </div>
                </div>
            </div>

            <div class="row">
                <div class="col-md-6">
                    <div class="mb-3">
                        <label asp-for="FromDateTime" class="form-label">From Date & Time</label>
                        <input asp-for="FromDateTime" type="datetime-local" class="form-control" />
                        <span asp-validation-for="FromDateTime" class="text-danger"></span>
                    </div>
                </div>
                <div class="col-md-6">
                    <div class="mb-3">
                        <label asp-for="ToDateTime" class="form-label">To Date & Time</label>
                        <input asp-for="ToDateTime" type="datetime-local" class="form-control" />
                        <span asp-validation-for="ToDateTime" class="text-danger"></span>
                    </div>
                </div>
            </div>

            <div class="mb-3">
                <label asp-for="Description" class="form-label">Description</label>
                <textarea asp-for="Description" class="form-control" rows="4" placeholder="Enter activity description"></textarea>
                <span asp-validation-for="Description" class="text-danger"></span>
            </div>

            <div class="mb-3">
                <label for="imageFile" class="form-label">Activity Image</label>
                @if (Model.ImageData != null)
                {
                    <div class="mb-2">
                        <img src="@Url.Action("GetImage", "ChurchActivity", new { id = Model.Id })" alt="Current Image" class="img-thumbnail" style="max-width: 200px;" />
                        <small class="d-block text-muted">Current image</small>
                    </div>
                }
                <input type="file" class="form-control" id="imageFile" name="imageFile" accept="image/*" />
                <small class="form-text text-muted">Upload a new image to replace current one (optional)</small>
            </div>

            <div class="form-check mb-3">
                <input asp-for="IsActive" class="form-check-input" type="checkbox" />
                <label asp-for="IsActive" class="form-check-label">Active</label>
            </div>

            <div class="d-flex justify-content-between">
                <a href="@Url.Action("Index")" class="btn btn-secondary">
                    <i class="fas fa-arrow-left me-1"></i>Back to List
                </a>
                <button type="submit" class="btn btn-primary">
                    <i class="fas fa-save me-1"></i>Update Activity
                </button>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}