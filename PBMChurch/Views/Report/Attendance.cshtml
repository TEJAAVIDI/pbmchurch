@model PBMChurch.Models.ViewModels.AttendanceReportViewModel
@{
    ViewData["Title"] = "Attendance Report";
}

<div class="page-header">
    <h2><i class="fas fa-chart-bar me-2"></i>Attendance Report</h2>
</div>

<div class="card">
    <div class="card-body">
        <form method="get" class="row g-3 mb-4">
            <div class="col-md-3">
                <label class="form-label">Church</label>
                <select name="churchId" class="form-select">
                    <option value="">All Churches</option>
                    @if (ViewBag.Churches != null)
                    {
                        @foreach (var church in ViewBag.Churches)
                        {
                            <option value="@church.Value" selected="@(church.Value == ViewBag.SelectedChurchId?.ToString())">@church.Text</option>
                        }
                    }
                </select>
            </div>
            <div class="col-md-3">
                <label class="form-label">From Date</label>
                <input type="date" name="fromDate" class="form-control" value="@ViewBag.FromDate" />
            </div>
            <div class="col-md-3">
                <label class="form-label">To Date</label>
                <input type="date" name="toDate" class="form-control" value="@ViewBag.ToDate" />
            </div>
            <div class="col-md-3">
                <label class="form-label">&nbsp;</label>
                <button type="submit" class="btn btn-primary w-100">
                    <i class="fas fa-search me-2"></i>Generate Report
                </button>
            </div>
        </form>

        @if (Model != null && Model.ReportData != null && Model.ReportData.Any())
        {
            <div class="alert alert-info">
                <i class="fas fa-info-circle me-2"></i>
                Showing attendance from <strong>@Model.Filters.FromDate?.ToString("yyyy-MM-dd")</strong> to <strong>@Model.Filters.ToDate?.ToString("yyyy-MM-dd")</strong>
            </div>

            <!-- Desktop Table -->
            <div class="table-responsive d-none d-md-block">
                <table class="table table-striped table-hover">
                    <thead>
                        <tr>
                            <th>Church</th>
                            <th>Total Records</th>
                            <th>Present</th>
                            <th>Absent</th>
                            <th>Attendance %</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var group in Model.ReportData.GroupBy(x => x.ChurchName))
                        {
                            var total = group.Count();
                            var present = group.Count(x => x.IsPresent);
                            var absent = total - present;
                            var percent = total > 0 ? (double)present / total * 100 : 0;
                            <tr>
                                <td>@group.Key</td>
                                <td>@total</td>
                                <td><span class="badge bg-success">@present</span></td>
                                <td><span class="badge bg-danger">@absent</span></td>
                                <td>
                                    <div class="progress" style="height: 25px;">
                                        <div class="progress-bar bg-success" style="width: @percent%">
                                            @percent.ToString("0.0")%
                                        </div>
                                    </div>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
            
            <!-- Mobile Cards -->
            <div class="d-md-none">
                @foreach (var group in Model.ReportData.GroupBy(x => x.ChurchName))
                {
                    var total = group.Count();
                    var present = group.Count(x => x.IsPresent);
                    var absent = total - present;
                    var percent = total > 0 ? (double)present / total * 100 : 0;
                    <div class="card mb-3">
                        <div class="card-body">
                            <h6 class="card-title mb-3">@group.Key</h6>
                            <p class="mb-1"><strong>Total Records:</strong> @total</p>
                            <p class="mb-1"><strong>Present:</strong> <span class="badge bg-success">@present</span></p>
                            <p class="mb-3"><strong>Absent:</strong> <span class="badge bg-danger">@absent</span></p>
                            <div class="mb-2">
                                <strong>Attendance:</strong>
                                <div class="progress mt-1" style="height: 25px;">
                                    <div class="progress-bar bg-success" style="width: @percent%">
                                        @percent.ToString("0.0")%
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                }
            </div>

            <div class="mt-3">
                <a href="#" class="btn btn-success">
                    <i class="fas fa-file-excel me-2"></i>Export to Excel
                </a>
                <a href="#" class="btn btn-danger">
                    <i class="fas fa-file-pdf me-2"></i>Export to PDF
                </a>
            </div>
        }
        else
        {
            <div class="text-center text-muted py-5">
                <i class="fas fa-chart-bar fa-3x mb-3"></i>
                <p>Select date range and click "Generate Report" to view attendance statistics</p>
            </div>
        }
    </div>
</div>
