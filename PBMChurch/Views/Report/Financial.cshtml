@{
    ViewData["Title"] = "Financial Report";
}

<div class="page-header">
    <h2><i class="fas fa-chart-line me-2"></i>Financial Report</h2>
</div>

<div class="card">
    <div class="card-body">
        <form method="get" class="row g-3 mb-4">
            <div class="col-md-3">
                <label class="form-label">Report Type</label>
                <select name="reportType" class="form-select">
                    <option value="summary">Summary</option>
                    <option value="detailed">Detailed</option>
                    <option value="byCategory">By Category</option>
                </select>
            </div>
            <div class="col-md-3">
                <label class="form-label">From Date</label>
                <input type="date" name="fromDate" class="form-control" value="@ViewBag.FromDate" />
            </div>
            <div class="col-md-3">
                <label class="form-label">To Date</label>
                <input type="date" name="toDate" class="form-control" value="@ViewBag.ToDate" />
            </div>
            <div class="col-md-3">
                <label class="form-label">&nbsp;</label>
                <button type="submit" class="btn btn-primary w-100">
                    <i class="fas fa-search me-2"></i>Generate Report
                </button>
            </div>
        </form>

        <div class="row mb-4">
            <div class="col-md-4">
                <div class="card bg-success text-white">
                    <div class="card-body">
                        <h5 class="card-title">Total Income</h5>
                        <h2>₹ @(ViewBag.TotalIncome ?? 0)</h2>
                    </div>
                </div>
            </div>
            <div class="col-md-4">
                <div class="card bg-danger text-white">
                    <div class="card-body">
                        <h5 class="card-title">Total Expenses</h5>
                        <h2>₹ @(ViewBag.TotalExpenses ?? 0)</h2>
                    </div>
                </div>
            </div>
            <div class="col-md-4">
                <div class="card bg-primary text-white">
                    <div class="card-body">
                        <h5 class="card-title">Net Balance</h5>
                        <h2>₹ @((ViewBag.TotalIncome ?? 0) - (ViewBag.TotalExpenses ?? 0))</h2>
                    </div>
                </div>
            </div>
        </div>

        @if (ViewBag.Transactions != null)
        {
            <div class="table-responsive">
                <table class="table table-striped table-hover">
                    <thead>
                        <tr>
                            <th>Date</th>
                            <th>Category</th>
                            <th>Description</th>
                            <th>Income</th>
                            <th>Expense</th>
                            <th>Balance</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var item in ViewBag.Transactions)
                        {
                            <tr>
                                <td>@item.Date</td>
                                <td>@item.Category</td>
                                <td>@item.Description</td>
                                <td>@(item.Income > 0 ? "₹ " + item.Income : "-")</td>
                                <td>@(item.Expense > 0 ? "₹ " + item.Expense : "-")</td>
                                <td>₹ @item.Balance</td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>

            <div class="mt-3">
                <a href="#" class="btn btn-success">
                    <i class="fas fa-file-excel me-2"></i>Export to Excel
                </a>
                <a href="#" class="btn btn-danger">
                    <i class="fas fa-file-pdf me-2"></i>Export to PDF
                </a>
            </div>
        }
        else
        {
            <div class="text-center text-muted py-5">
                <i class="fas fa-chart-line fa-3x mb-3"></i>
                <p>Select date range and click "Generate Report" to view financial data</p>
            </div>
        }
    </div>
</div>
