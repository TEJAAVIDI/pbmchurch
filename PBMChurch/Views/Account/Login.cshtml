@model PBMChurch.Models.ViewModels.LoginViewModel

<!DOCTYPE html>
<html lang="en" style="overflow-x: hidden;">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Login - PBM Church Management</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css" />
    <style>
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }

        html,
        body {
            overflow-x: hidden;
        }

        html::-webkit-scrollbar,
        body::-webkit-scrollbar {
            width: 0px;
            height: 0px;
            background: transparent;
        }

        html,
        body {
            -ms-overflow-style: none;
            scrollbar-width: none;
        }

        body {
            font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, 'Helvetica Neue', Arial, sans-serif;
            background: #f5f7fa;
            min-height: 100vh;
            display: flex;
            align-items: center;
            justify-content: center;
            padding: 20px;
        }

        .login-container {
            display: flex;
            width: 100%;
            max-width: 1000px;
            background: white;
            border-radius: 0.5rem;
            overflow: hidden;
            box-shadow: 0 4px 8px rgba(0, 0, 0, 0.1);
            border: 1px solid #dfe6e9;
        }

        .login-left {
            flex: 1;
            width: 50%;
            background: #2c3e50;
            color: white;
            display: flex;
            align-items: center;
            justify-content: center;
            padding: 60px 40px;
            position: relative;
            overflow: hidden;
        }

        .login-left::before {
            content: '';
            position: absolute;
            width: 500px;
            height: 500px;
            background: rgba(255, 255, 255, 0.1);
            border-radius: 50%;
            top: -200px;
            right: -200px;
        }

        .login-left::after {
            content: '';
            position: absolute;
            width: 300px;
            height: 300px;
            background: rgba(255, 255, 255, 0.08);
            border-radius: 50%;
            bottom: -100px;
            left: -100px;
        }

        .brand-content {
            position: relative;
            z-index: 1;
            text-align: center;
            max-width: 500px;
        }

        .brand-logo {
            font-size: 4rem;
            margin-bottom: 20px;
            animation: fadeInDown 1s;
        }

        .brand-logo img {
            max-width: 180px;
            height: auto;
        }

        .brand-content h1 {
            font-size: 1.875rem;
            font-weight: 600;
            margin-bottom: 15px;
            animation: fadeInUp 1s;
            letter-spacing: -0.3px;
        }

        .brand-content p {
            font-size: 1rem;
            opacity: 0.9;
            line-height: 1.5;
            margin-bottom: 30px;
            animation: fadeInUp 1.2s;
        }

        .brand-features {
            display: flex;
            justify-content: center;
            gap: 25px;
            font-size: 1.75rem;
            animation: fadeInUp 1.4s;
        }

        .brand-features i {
            opacity: 0.8;
            transition: all 0.3s;
        }

        .brand-features i:hover {
            opacity: 1;
            transform: scale(1.2);
        }

        .login-form-section {
            flex: 1;
            width: 50%;
            background: white;
            display: flex;
            flex-direction: column;
            justify-content: center;
            padding: 50px 40px;
            overflow-y: auto;
        }

        .login-header {
            margin-bottom: 40px;
        }

        .login-header h1 {
            font-size: 1.5rem;
            color: #2c3e50;
            font-weight: 600;
        }

        .alert {
            padding: 12px 16px;
            border-radius: 0.375rem;
            margin-bottom: 16px;
            display: flex;
            align-items: center;
            gap: 10px;
            border: 1px solid;
            font-size: 0.875rem;
        }

        .alert-danger {
            background: rgba(192,57,43,0.05);
            color: #c0392b;
            border-color: rgba(192,57,43,0.2);
        }

        .alert-success {
            background: rgba(39,174,96,0.05);
            color: #27ae60;
            border-color: rgba(39,174,96,0.2);
        }

        .input-wrapper {
            position: relative;
            margin-bottom: 25px;
        }

        .form-label {
            display: block;
            margin-bottom: 6px;
            color: #2c3e50;
            font-weight: 500;
            font-size: 0.875rem;
        }

        .input-wrapper > i {
            position: absolute;
            left: 12px;
            top: 40px;
            color: #7f8c8d;
            font-size: 1rem;
        }

        .form-control {
            width: 100%;
            padding: 10px 10px 10px 38px;
            border: 1px solid #dfe6e9;
            border-radius: 0.375rem;
            font-size: 0.875rem;
            transition: all 0.2s;
        }

        .form-control:focus {
            outline: none;
            border-color: #16a085;
            box-shadow: 0 0 0 3px rgba(22, 160, 133, 0.1);
        }

        .password-toggle {
            position: absolute;
            right: 12px;
            top: 40px;
            background: none;
            border: none;
            color: #7f8c8d;
            cursor: pointer;
            font-size: 1rem;
            transition: color 0.2s;
        }

        .password-toggle:hover {
            color: #16a085;
        }

        .form-options {
            margin-bottom: 25px;
        }

        .form-check {
            display: flex;
            align-items: center;
        }

        .form-check-input {
            width: 18px;
            height: 18px;
            margin-right: 8px;
            cursor: pointer;
        }

        .form-check-label {
            color: #666;
            cursor: pointer;
        }

        .btn-primary {
            width: 100%;
            padding: 12px;
            background: #2c3e50;
            color: white;
            border: none;
            border-radius: 0.375rem;
            font-size: 0.875rem;
            font-weight: 500;
            cursor: pointer;
            transition: all 0.2s;
            display: flex;
            align-items: center;
            justify-content: center;
            gap: 8px;
        }

        .btn-primary:hover {
            transform: translateY(-1px);
            box-shadow: 0 4px 8px rgba(44, 62, 80, 0.2);
            background: #1a252f;
        }

        .signup-text {
            text-align: center;
            color: #666;
            margin-top: 20px;
        }

        .signup-text a {
            color: #0d6efd;
            text-decoration: none;
            font-weight: 600;
        }

        .signup-text a:hover {
            text-decoration: underline;
        }

        .text-danger {
            color: #c33;
            font-size: 0.85rem;
            margin-top: 5px;
            display: block;
        }

        @@keyframes fadeInDown {
            from {
                opacity: 0;
                transform: translateY(-30px);
            }
            to {
                opacity: 1;
                transform: translateY(0);
            }
        }

        @@keyframes fadeInUp {
            from {
                opacity: 0;
                transform: translateY(30px);
            }
            to {
                opacity: 1;
                transform: translateY(0);
            }
        }

        @@media (max-width: 992px) {
            .login-container {
                flex-direction: column;
                max-width: 500px;
            }
            
            .login-left,
            .login-form-section {
                width: 100%;
            }
            
            .login-left {
                padding: 40px 20px;
                min-height: auto;
            }
            
            .brand-content h1 {
                font-size: 1.8rem;
            }
            
            .brand-content p {
                font-size: 1rem;
            }
            
            .brand-features {
                font-size: 1.5rem;
                gap: 20px;
            }
            
            .login-form-section {
                padding: 40px 30px;
            }
        }
    </style>
</head>
<body>
    <div class="login-container">
        <div class="login-left">
        <div class="brand-content">
            <div class="brand-logo">
                <i class="fas fa-church"></i>
            </div>
            <h1>PBM Church Management System</h1>
            <p>Streamline your church management with our powerful platform designed for modern ministry.</p>
            <div class="brand-features">
                <i class="fas fa-users"></i>
                <i class="fas fa-church"></i>
                <i class="fas fa-hands-praying"></i>
            </div>
        </div>
    </div>

    <div class="login-form-section">
        <div class="login-header">
            <h1>Welcome Back</h1>
        </div>

        @if (ViewBag.Message != null)
        {
            <div class="alert alert-danger" role="alert">
                <i class="fas fa-exclamation-circle"></i>
                <span>@ViewBag.Message</span>
            </div>
        }
        
        @if (TempData["PasswordResetSuccess"] != null)
        {
            <div class="alert alert-success" role="alert">
                <i class="fas fa-check-circle"></i>
                <span>@TempData["PasswordResetSuccess"]</span>
            </div>
        }
        
        <form asp-action="Login" method="post">
            <div asp-validation-summary="All" class="text-danger mb-3"></div>

            <div class="input-wrapper">
                <label asp-for="Username" class="form-label">Username</label>
                <i class="fas fa-user"></i>
                <input asp-for="Username" class="form-control" placeholder="Enter your username" required autofocus />
                <span asp-validation-for="Username" class="text-danger"></span>
            </div>
            
            <div class="input-wrapper">
                <label asp-for="Password" class="form-label">Password</label>
                <i class="fas fa-lock"></i>
                <input asp-for="Password" class="form-control" type="password" id="passwordInput" placeholder="Enter your password" required />
                <button type="button" class="password-toggle" id="togglePassword">
                    <i class="fas fa-eye" id="toggleIcon"></i>
                </button>
                <span asp-validation-for="Password" class="text-danger"></span>
            </div>
            
            <div class="form-options">
                <div class="form-check">
                    <input asp-for="RememberMe" class="form-check-input" type="checkbox" id="rememberMe" />
                    <label asp-for="RememberMe" class="form-check-label" for="rememberMe">
                        Remember me
                    </label>
                </div>
            </div>
            
            <button type="submit" class="btn-primary">
                <i class="fas fa-sign-in-alt"></i>Sign In
            </button>
            
            <p class="signup-text">
                New to PBM Church? <a href="/">Visit Our Website</a>
            </p>
        </form>
    </div>
    </div>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/lib/jquery-validation/dist/jquery.validate.min.js"></script>
    <script src="~/lib/jquery-validation-unobtrusive/jquery.validate.unobtrusive.min.js"></script>
    <script>
        document.getElementById('togglePassword').addEventListener('click', function () {
            const passwordInput = document.getElementById('passwordInput');
            const toggleIcon = document.getElementById('toggleIcon');
            
            if (passwordInput.type === 'password') {
                passwordInput.type = 'text';
                toggleIcon.classList.remove('fa-eye');
                toggleIcon.classList.add('fa-eye-slash');
            } else {
                passwordInput.type = 'password';
                toggleIcon.classList.remove('fa-eye-slash');
                toggleIcon.classList.add('fa-eye');
            }
        });
    </script>
</body>
</html>
