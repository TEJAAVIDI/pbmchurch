</style>

<style>
    .pagination {
        margin-bottom: 0;
    }
    
    .page-link {
        color: #2c3e50;
        border: 1px solid #dfe6e9;
        padding: 0.375rem 0.75rem;
        font-size: 0.875rem;
    }
    
    .page-link:hover {
        background-color: #f5f7fa;
        border-color: #2c3e50;
        color: #2c3e50;
    }
    
    .page-item.active .page-link {
        background-color: #2c3e50;
        border-color: #2c3e50;
        color: white;
