@model List<PBMChurch.Models.WishTemplate>
@{
    ViewData["Title"] = "Wishes Management";
    var bibleReading = ViewBag.BibleReading as PBMChurch.Models.BibleReading;
    var todaysBirthdays = ViewBag.TodaysBirthdays as List<PBMChurch.Models.Member>;
}

<div class="container-fluid">
    <div class="row">
        <div class="col-12">
            <div class="mb-4">
                <div class="row align-items-center">
                    <div class="col-12 col-md-6">
                        <h4><i class="fas fa-heart text-danger"></i> Wishes Management</h4>
                    </div>
                    <div class="col-12 col-md-6">
                        <div class="btn-group-responsive">
                            <a href="@Url.Action("Create", new { type = "Birthday" })" class="btn btn-primary btn-sm">
                                <i class="fas fa-birthday-cake me-1"></i>Birthday
                            </a>
                            <a href="@Url.Action("Create", new { type = "Anniversary" })" class="btn btn-success btn-sm">
                                <i class="fas fa-ring me-1"></i>Anniversary
                            </a>
                            <a href="@Url.Action("Create", new { type = "Event" })" class="btn btn-info btn-sm">
                                <i class="fas fa-calendar-alt me-1"></i>Event
                            </a>
                            <a href="@Url.Action("Create", new { type = "General" })" class="btn btn-secondary btn-sm">
                                <i class="fas fa-plus me-1"></i>General
                            </a>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <!-- Bible Reading Section -->
    @if (bibleReading != null)
    {
        <div class="row mb-4">
            <div class="col-12">
                <div class="card border-primary">
                    <div class="card-header bg-primary text-white">
                        <h5 class="mb-0"><i class="fas fa-book-open"></i> Today's Bible Reading - Day @bibleReading.CurrentDay of @bibleReading.Year</h5>
                    </div>
                    <div class="card-body">
                        <div class="row">
                            <div class="col-md-4">
                                <strong>Chapters Per Day:</strong> @bibleReading.ChaptersPerDay
                            </div>
                            <div class="col-md-4">
                                <strong>Today's Reading:</strong> @ViewBag.ReadingRange
                            </div>
                            <div class="col-md-4">
                                <strong>Progress:</strong> @Math.Round((decimal)bibleReading.CurrentDay / 365 * 100, 1)%
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    }

    <!-- Wish Templates Section -->
    <div class="row">
        @foreach (var group in Model.GroupBy(w => w.Type))
        {
            <div class="col-lg-6 mb-4">
                <div class="card">
                    <div class="card-header">
                        <div class="d-flex justify-content-between align-items-center flex-wrap">
                            <h5 class="mb-0 card-title-mobile">
                                @switch (group.Key)
                                {
                                    case "Birthday":
                                        <i class="fas fa-birthday-cake text-primary"></i>
                                        break;
                                    case "Anniversary":
                                        <i class="fas fa-ring text-success"></i>
                                        break;
                                    case "Event":
                                        <i class="fas fa-calendar-alt text-info"></i>
                                        break;
                                    case "Bible":
                                        <i class="fas fa-book text-warning"></i>
                                        break;
                                    default:
                                        <i class="fas fa-heart text-danger"></i>
                                        break;
                                }
                                @group.Key Templates (@group.Count())
                            </h5>
                            <a href="@Url.Action("Create", new { type = group.Key })" class="btn btn-sm btn-outline-light card-add-btn">
                                <i class="fas fa-plus me-1"></i>Add
                            </a>
                        </div>
                    </div>
                    <div class="card-body">
                        @foreach (var wish in group.Take(3))
                        {
                            <div class="border-bottom pb-2 mb-2">
                                <div class="row">
                                    @if (wish.ImageData != null)
                                    {
                                        <div class="col-3">
                                            <img src="@Url.Action("GetImage", "Wishes", new { id = wish.Id })" class="img-thumbnail" style="max-height: 60px;" alt="Wish Image">
                                        </div>
                                        <div class="col-7">
                                            @if (!string.IsNullOrEmpty(wish.MessageText))
                                            {
                                                @if (wish.Type == "Bible" && bibleReading != null)
                                                {
                                                    var readingRange = ViewBag.ReadingRange?.ToString() ?? "";
                                                    var formattedMessage = wish.MessageText.Replace("{StartChapter}", readingRange).Replace("{EndChapter}", "").Replace(" to ", "");
                                                    <small class="text-muted">@(formattedMessage.Length > 100 ? formattedMessage.Substring(0, 100) + "..." : formattedMessage)</small>
                                                }
                                                else
                                                {
                                                    <small class="text-muted">@(wish.MessageText.Length > 100 ? wish.MessageText.Substring(0, 100) + "..." : wish.MessageText)</small>
                                                }
                                            }
                                            @if (!string.IsNullOrEmpty(wish.YouTubeUrl))
                                            {
                                                <br><small class="text-info"><i class="fab fa-youtube"></i> YouTube Link</small>
                                            }
                                        </div>
                                    }
                                    else
                                    {
                                        <div class="col-10">
                                            @if (!string.IsNullOrEmpty(wish.MessageText))
                                            {
                                                @if (wish.Type == "Bible" && bibleReading != null)
                                                {
                                                    var readingRange = ViewBag.ReadingRange?.ToString() ?? "";
                                                    var formattedMessage = wish.MessageText.Replace("{StartChapter}", readingRange).Replace("{EndChapter}", "").Replace(" to ", "");
                                                    <small class="text-muted">@(formattedMessage.Length > 100 ? formattedMessage.Substring(0, 100) + "..." : formattedMessage)</small>
                                                }
                                                else
                                                {
                                                    <small class="text-muted">@(wish.MessageText.Length > 100 ? wish.MessageText.Substring(0, 100) + "..." : wish.MessageText)</small>
                                                }
                                            }
                                            @if (!string.IsNullOrEmpty(wish.YouTubeUrl))
                                            {
                                                <br><small class="text-info"><i class="fab fa-youtube"></i> YouTube Link</small>
                                            }
                                        </div>
                                    }
                                    <div class="col-2 text-end">
                                        <div class="btn-group-vertical btn-group-sm">
                                            <a href="@Url.Action("Edit", new { id = wish.Id })" class="btn btn-outline-primary btn-sm">
                                                <i class="fas fa-edit"></i>
                                            </a>
                                            <button class="btn btn-outline-danger btn-sm" onclick="deleteWish(@wish.Id)">
                                                <i class="fas fa-trash"></i>
                                            </button>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        }
                        @if (group.Count() > 3)
                        {
                            <small class="text-muted">... and @(group.Count() - 3) more</small>
                        }
                    </div>
                </div>
            </div>
        }
    </div>
</div>

@section Scripts {
    <script>
        function sendBirthdayWish(memberId) {
            alert('Opening phone dialer for birthday call...');
        }

        function sendWhatsAppWish(memberId, messageType) {
            $.post('@Url.Action("SendWhatsAppMessage")', {
                memberId: memberId,
                messageType: messageType
            }, function(response) {
                if (response.success) {
                    window.open(response.url, '_blank');
                } else {
                    alert('Error: ' + response.message);
                }
            });
        }

        function deleteWish(id) {
            if (confirm('Are you sure you want to delete this wish template?')) {
                $.post('@Url.Action("Delete")', { id: id }, function() {
                    location.reload();
                });
            }
        }

        function checkMidnight() {
            var now = new Date();
            if (now.getHours() === 0 && now.getMinutes() === 0) {
                location.reload();
            }
        }
        setInterval(checkMidnight, 60000);
    </script>
    
    <style>
        .btn-group-responsive {
            display: flex;
            gap: 8px;
            justify-content: flex-end;
        }
        
        .btn-group-responsive .btn {
            white-space: nowrap;
            display: inline-flex;
            align-items: center;
        }
        
        @@media (max-width: 768px) {
            .btn-group-responsive {
                justify-content: center;
                margin-top: 15px;
                flex-wrap: wrap;
            }
            
            .btn-group-responsive .btn {
                flex: 1;
                min-width: 120px;
            }
            
            .card-header .d-flex {
                flex-direction: column;
                align-items: flex-start !important;
            }
            
            .card-title-mobile {
                width: 100%;
                margin-bottom: 10px;
            }
            
            .card-add-btn {
                align-self: flex-end;
            }
        }
    </style>
}