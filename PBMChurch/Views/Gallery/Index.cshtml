@model IEnumerable<PBMChurch.Models.GalleryImage>

@{
    ViewData["Title"] = "Gallery Management";
}

<div class="page-header">
    <h2><i class="fas fa-images me-2"></i>Gallery Management</h2>
    <a asp-action="Create" class="btn btn-primary">
        <i class="fas fa-plus me-1"></i>Upload Image
    </a>
</div>

<div class="card">
    <div class="card-body">
        <div class="alert alert-info">
            <i class="fas fa-info-circle me-2"></i>
            <strong>Info:</strong> Images uploaded here will appear on the landing page gallery section.
            Manage your church photos, events, and activities.
        </div>

        @if (!Model.Any())
        {
            <div class="text-center py-5">
                <i class="fas fa-images fa-4x text-muted mb-3"></i>
                <h4 class="text-muted">No images in gallery</h4>
                <p class="text-muted">Upload your first image to get started</p>
                <a asp-action="Create" class="btn btn-primary mt-3">
                    <i class="fas fa-upload me-2"></i>Upload Image
                </a>
            </div>
        }
        else
        {
            <div class="row g-4">
                @foreach (var item in Model)
                {
                    <div class="col-md-6 col-lg-4 col-xl-3">
                        <div class="card h-100 shadow-sm">
                            <div class="position-relative">
                                <img src="@item.ImagePath" class="card-img-top" alt="@item.Title" 
                                     style="height: 200px; object-fit: cover;">
                                @if (!item.IsActive)
                                {
                                    <span class="position-absolute top-0 end-0 badge bg-danger m-2">Inactive</span>
                                }
                                else
                                {
                                    <span class="position-absolute top-0 end-0 badge bg-success m-2">Active</span>
                                }
                            </div>
                            <div class="card-body">
                                <h5 class="card-title">
                                    @if (!string.IsNullOrEmpty(item.Title))
                                    {
                                        @item.Title
                                    }
                                    else
                                    {
                                        <span class="text-muted">No Title</span>
                                    }
                                </h5>
                                <p class="card-text text-muted small">
                                    @if (!string.IsNullOrEmpty(item.Description))
                                    {
                                        @item.Description
                                    }
                                    else
                                    {
                                        <em>No description</em>
                                    }
                                </p>
                                <div class="small">
                                    <div class="mb-1">
                                        <i class="fas fa-church text-primary me-1"></i>
                                        <strong>Church:</strong> @(item.Church?.ChurchName ?? "All")
                                    </div>
                                    <div class="mb-1">
                                        <i class="fas fa-tag text-info me-1"></i>
                                        <strong>Category:</strong> @(item.Category ?? "General")
                                    </div>
                                    <div class="mb-1">
                                        <i class="fas fa-sort-numeric-up text-secondary me-1"></i>
                                        <strong>Order:</strong> @item.DisplayOrder
                                    </div>
                                    <div>
                                        <i class="fas fa-calendar text-success me-1"></i>
                                        <strong>Uploaded:</strong> @item.UploadedDate.ToString("MMM dd, yyyy")
                                    </div>
                                </div>
                            </div>
                            <div class="card-footer bg-white border-top">
                                <div class="d-flex gap-2">
                                    <a asp-action="Edit" asp-route-id="@item.ImageId" class="btn btn-sm btn-warning flex-fill">
                                        <i class="fas fa-edit"></i> Edit
                                    </a>
                                    <form asp-action="Delete" asp-route-id="@item.ImageId" method="post" 
                                          class="flex-fill" onsubmit="return confirm('Are you sure you want to delete this image?');">
                                        @Html.AntiForgeryToken()
                                        <button type="submit" class="btn btn-sm btn-danger w-100">
                                            <i class="fas fa-trash"></i> Delete
                                        </button>
                                    </form>
                                </div>
                            </div>
                        </div>
                    </div>
                }
            </div>
        }
    </div>
</div>

@section Scripts {
    <script>
        // Auto-hide success/error messages after 5 seconds
        setTimeout(function() {
            $('.alert-dismissible').fadeOut('slow');
        }, 5000);
    </script>
}
