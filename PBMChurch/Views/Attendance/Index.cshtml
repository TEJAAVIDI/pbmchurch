        function scrollAttendance(button, direction) {
            const container = $(button).siblings('.attendance-badges')[0];
            const scrollAmount = 200;
            
            if (direction === 'left') {
                container.scrollLeft -= scrollAmount;
            } else {
                container.scrollLeft += scrollAmount;
            }
            
            // Update button visibility after scroll
            setTimeout(function() {
                updateNavButtons(container);
            }, 300);
        }

        function updateNavButtons(container) {
            const $container = $(container);
            const scrollLeft = $container.scrollLeft();
            const scrollWidth = $container[0].scrollWidth;
            const clientWidth = $container[0].clientWidth;
            
            const $parent = $container.parent();
            const $leftBtn = $parent.find('.attendance-nav-left');
            const $rightBtn = $parent.find('.attendance-nav-right');
            
            // Show/hide left button
            if (scrollLeft > 10) {
                $leftBtn.show();
            } else {
                $leftBtn.hide();
            }
            
            // Show/hide right button
            if (scrollLeft + clientWidth < scrollWidth - 10) {
                $rightBtn.show();
            } else {
                $rightBtn.hide();
            }
        }

        function quickMarkPresent(userId, memberName) {
            const attendanceDate = $('#attendanceDate').val();

            $.ajax({
                url: '/Attendance/MarkPresent',
                type: 'POST',
                data: {
                    churchId: selectedChurchId,
                    userId: userId,
                    attendanceDate: attendanceDate,
                    __RequestVerificationToken: $('input[name="__RequestVerificationToken"]').val()
                },
                success: function(response) {
                    if (response.success) {
                        showAlert(`✓ ${memberName} marked as Present!`, 'success');
                        showAbsentMembers(); // Refresh the absent list
                    } else {
                        showAlert(response.message || 'Failed to mark attendance', 'danger');
                    }
                },
                error: function() {
                    showAlert('Error marking attendance. Please try again.', 'danger');
                }
            });
        }

        function deleteAttendance(attendanceId, memberName) {
            if (!confirm(`Are you sure you want to delete attendance record for ${memberName}?\n\nThis will mark them as absent again.`)) {
                return;
            }

            $.ajax({
                url: '/Attendance/DeleteAttendance',
                type: 'POST',
                data: {
                    id: attendanceId,
                    __RequestVerificationToken: $('input[name="__RequestVerificationToken"]').val()
                },
                success: function(response) {
                    if (response.success) {
                        showAlert(`✓ Attendance record for ${memberName} deleted successfully!`, 'success');
                        loadTodayAttendance();
                    } else {
                        showAlert(response.message || 'Failed to delete attendance', 'danger');
                    }
                },
                error: function() {
                    showAlert('Error deleting attendance. Please try again.', 'danger');
                }
            });
        }

        function showAlert(message, type) {
            const iconMap = {
                'success': 'check-circle',
                'danger': 'times-circle',
                'warning': 'exclamation-triangle',
                'info': 'info-circle'
            };
            
            const icon = iconMap[type] || 'info-circle';
            
            const alert = `
                <div class="alert alert-${type} alert-dismissible fade show" role="alert">
                    <i class="fas fa-${icon} me-2"></i>${message}
                    <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
                </div>
            `;
            
            $('#alertContainer').html(alert);
            
            // Auto-dismiss success messages after 3 seconds
            if (type === 'success') {
                setTimeout(function() {
                    $('#alertContainer .alert').fadeOut();
                }, 3000);
            }
        }
