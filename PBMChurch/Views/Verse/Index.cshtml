@model IEnumerable<PBMChurch.Models.Verse>
@{
    ViewData["Title"] = "Daily Verses & Messages";
}

<div class="page-header">
    <h2><i class="fas fa-bible me-2"></i>Daily Verses & Messages</h2>
</div>

<div class="card">
    <div class="card-body">
        <ul class="nav nav-tabs mb-3" role="tablist">
            <li class="nav-item">
                <a class="nav-link active" data-bs-toggle="tab" href="#dailyVerse">Daily Verse</a>
            </li>
            <li class="nav-item">
                <a class="nav-link" data-bs-toggle="tab" href="#eventMessages">Special Events</a>
            </li>
            <li class="nav-item">
                <a class="nav-link" data-bs-toggle="tab" href="#otherMessages">Other Messages</a>
            </li>
        </ul>

        <div class="tab-content">
            <!-- Daily Verse Tab -->
            <div class="tab-pane fade show active" id="dailyVerse">
                <!-- Bible Templates -->
                <div class="row">
                    @foreach (var template in ViewBag.BibleTemplates as List<PBMChurch.Models.WishTemplate> ?? new List<PBMChurch.Models.WishTemplate>())
                    {
                        <div class="col-md-6 mb-3">
                            <div class="card border-primary">
                                <div class="card-body">
                                    <div class="row">
                                        @if (template.ImageData != null)
                                        {
                                            <div class="col-4">
                                                <img src="@Url.Action("GetImage", "Wishes", new { id = template.Id })" class="img-fluid rounded" alt="Bible Image">
                                            </div>
                                            <div class="col-8">
                                                <h6 class="card-title">Bible Message</h6>
                                                <p class="card-text">@(template.MessageText?.Length > 100 ? template.MessageText.Substring(0, 100) + "..." : template.MessageText)</p>
                                                <div class="btn-group" role="group">
                                                    <a href="@Url.Action("Edit", "Wishes", new { id = template.Id })" class="btn btn-outline-secondary btn-sm">
                                                        <i class="fas fa-edit"></i> Edit
                                                    </a>
                                                    <button class="btn btn-success btn-sm" onclick="sendMessage('@template.Id', 'bible')">
                                                        <i class="fab fa-whatsapp"></i> Send
                                                    </button>
                                                </div>
                                            </div>
                                        }
                                        else
                                        {
                                            <div class="col-12">
                                                <h6 class="card-title">Bible Message</h6>
                                                <p class="card-text">@(template.MessageText?.Length > 100 ? template.MessageText.Substring(0, 100) + "..." : template.MessageText)</p>
                                                <div class="btn-group" role="group">
                                                    <a href="@Url.Action("Edit", "Wishes", new { id = template.Id })" class="btn btn-outline-secondary btn-sm">
                                                        <i class="fas fa-edit"></i> Edit
                                                    </a>
                                                    <button class="btn btn-success btn-sm" onclick="sendMessage('@template.Id', 'bible')">
                                                        <i class="fab fa-whatsapp"></i> Send
                                                    </button>
                                                </div>
                                            </div>
                                        }
                                    </div>
                                </div>
                            </div>
                        </div>
                    }
                </div>
            </div>

            <!-- Special Events Tab -->
            <div class="tab-pane fade" id="eventMessages">
                <div class="row">
                    @if (ViewBag.EventTemplates != null && (ViewBag.EventTemplates as List<PBMChurch.Models.WishTemplate>).Any())
                    {
                        @foreach (var template in ViewBag.EventTemplates as List<PBMChurch.Models.WishTemplate>)
                        {
                            <div class="col-12 mb-3">
                                <div class="card border-info">
                                    <div class="card-body">
                                        <div class="row">
                                            @if (template.ImageData != null)
                                            {
                                                <div class="col-3">
                                                    <img src="@Url.Action("GetImage", "Wishes", new { id = template.Id })" class="img-fluid rounded" alt="Event Image">
                                                </div>
                                                <div class="col-9">
                                                    <h6 class="card-title">Event Message</h6>
                                                    <p class="card-text">@template.MessageText</p>
                                                    @if (!string.IsNullOrEmpty(template.YouTubeUrl))
                                                    {
                                                        <small class="text-info d-block mb-2"><i class="fab fa-youtube"></i> YouTube Link Available</small>
                                                    }
                                                    <div class="btn-group" role="group">
                                                        <a href="@Url.Action("Edit", "Wishes", new { id = template.Id })" class="btn btn-outline-secondary btn-sm">
                                                            <i class="fas fa-edit"></i> Edit
                                                        </a>
                                                        <button class="btn btn-success btn-sm" onclick="sendMessage('@template.Id', 'event')">
                                                            <i class="fab fa-whatsapp"></i> Send
                                                        </button>
                                                    </div>
                                                </div>
                                            }
                                            else
                                            {
                                                <div class="col-12">
                                                    <h6 class="card-title">Event Message</h6>
                                                    <p class="card-text">@template.MessageText</p>
                                                    @if (!string.IsNullOrEmpty(template.YouTubeUrl))
                                                    {
                                                        <small class="text-info d-block mb-2"><i class="fab fa-youtube"></i> YouTube Link Available</small>
                                                    }
                                                    <div class="btn-group" role="group">
                                                        <a href="@Url.Action("Edit", "Wishes", new { id = template.Id })" class="btn btn-outline-secondary btn-sm">
                                                            <i class="fas fa-edit"></i> Edit
                                                        </a>
                                                        <button class="btn btn-success btn-sm" onclick="sendMessage('@template.Id', 'event')">
                                                            <i class="fab fa-whatsapp"></i> Send
                                                        </button>
                                                    </div>
                                                </div>
                                            }
                                        </div>
                                    </div>
                                </div>
                            </div>
                        }
                    }
                    else
                    {
                        <div class="col-12">
                            <div class="alert alert-info">
                                <i class="fas fa-info-circle me-2"></i>
                                No special event messages available. Add them in Wishes Management.
                            </div>
                        </div>
                    }
                </div>
            </div>

            <!-- Other Messages Tab -->
            <div class="tab-pane fade" id="otherMessages">
                <div class="row">
                    @if (ViewBag.GeneralTemplates != null && (ViewBag.GeneralTemplates as List<PBMChurch.Models.WishTemplate>).Any())
                    {
                        @foreach (var template in ViewBag.GeneralTemplates as List<PBMChurch.Models.WishTemplate>)
                        {
                            <div class="col-12 mb-3">
                                <div class="card border-secondary">
                                    <div class="card-body">
                                        <div class="row">
                                            @if (template.ImageData != null)
                                            {
                                                <div class="col-3">
                                                    <img src="@Url.Action("GetImage", "Wishes", new { id = template.Id })" class="img-fluid rounded" alt="General Image">
                                                </div>
                                                <div class="col-9">
                                                    <h6 class="card-title">General Message</h6>
                                                    <p class="card-text">@template.MessageText</p>
                                                    <div class="btn-group" role="group">
                                                        <a href="@Url.Action("Edit", "Wishes", new { id = template.Id })" class="btn btn-outline-secondary btn-sm">
                                                            <i class="fas fa-edit"></i> Edit
                                                        </a>
                                                        <button class="btn btn-success btn-sm" onclick="sendMessage('@template.Id', 'general')">
                                                            <i class="fab fa-whatsapp"></i> Send
                                                        </button>
                                                    </div>
                                                </div>
                                            }
                                            else
                                            {
                                                <div class="col-12">
                                                    <h6 class="card-title">General Message</h6>
                                                    <p class="card-text">@template.MessageText</p>
                                                    <div class="btn-group" role="group">
                                                        <a href="@Url.Action("Edit", "Wishes", new { id = template.Id })" class="btn btn-outline-secondary btn-sm">
                                                            <i class="fas fa-edit"></i> Edit
                                                        </a>
                                                        <button class="btn btn-success btn-sm" onclick="sendMessage('@template.Id', 'general')">
                                                            <i class="fab fa-whatsapp"></i> Send
                                                        </button>
                                                    </div>
                                                </div>
                                            }
                                        </div>
                                    </div>
                                </div>
                            </div>
                        }
                    }
                    else
                    {
                        <div class="col-12">
                            <div class="alert alert-info">
                                <i class="fas fa-info-circle me-2"></i>
                                No general messages available. Add them in Wishes Management.
                            </div>
                        </div>
                    }
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        var templates = {
            bible: @Html.Raw(Json.Serialize(ViewBag.BibleTemplates ?? new List<object>())),
            event: @Html.Raw(Json.Serialize(ViewBag.EventTemplates ?? new List<object>())),
            general: @Html.Raw(Json.Serialize(ViewBag.GeneralTemplates ?? new List<object>()))
        };

        var bibleReading = '@ViewBag.BibleReading';
        var dayOfYear = @ViewBag.DayOfYear;

        function sendMessage(templateId, type) {
            var template = templates[type].find(t => t.id == templateId);
            if (!template) return;

            var message = template.messageText || '';
            if (type === 'event' && template.youTubeUrl) {
                message += '\n' + template.youTubeUrl;
            }

            var encodedMessage = encodeURIComponent(message);
            
            // If template has image, copy message and open image, then open WhatsApp
            if (template.imageData) {
                navigator.clipboard.writeText(message).then(() => {
                    // Open image in new tab for copying
                    window.open('/Wishes/GetImage/' + templateId, '_blank');
                    // Open WhatsApp
                    window.open('https://wa.me/?text=' + encodedMessage, '_blank');
                });
            } else {
                // No image, direct WhatsApp
                var whatsappUrl = 'https://wa.me/?text=' + encodedMessage;
                window.open(whatsappUrl, '_blank');
            }
        }

        function sendToMultipleGroups(templateId, type) {
            var template = templates[type].find(t => t.id == templateId);
            if (!template) return;

            var message = template.messageText || '';
            if (type === 'event' && template.youTubeUrl) {
                message += '\n' + template.youTubeUrl;
            }

            // Copy message to clipboard
            navigator.clipboard.writeText(message).then(() => {
                if (template.imageData) {
                    alert('Message copied! Image will open in new tab. Send to multiple groups:\n\n1. Paste message + image in Group 1\n2. Paste message + image in Group 2\n3. Paste message + image in Group 3\n4. Continue for all your groups...');
                    window.open('/Wishes/GetImage/' + templateId, '_blank');
                } else {
                    alert('Message copied! Send to multiple groups:\n\n1. Open WhatsApp Group 1 and paste\n2. Open WhatsApp Group 2 and paste\n3. Open WhatsApp Group 3 and paste\n4. Continue for all your groups...');
                }
            });
        }
    </script>
}